rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerEmail() {
      return "stanleyhoh79@gmail.com";
    }

    function isOwner() {
      return signedIn() && request.auth.token.email == ownerEmail();
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.token.email)).data.enabled != false;
    }

    // MVP wallet data. Client-side transfers currently need authenticated writes.
    match /wallets/{userId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    // Merchant profiles, QR payments, orders, refunds and settlements.
    match /merchants/{merchantId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    // User/admin workflow collections.
    match /rechargeRequests/{requestId} {
      allow read, write: if signedIn();
    }

    match /withdrawRequests/{requestId} {
      allow read, write: if signedIn();
    }

    match /refundRequests/{requestId} {
      allow read, write: if signedIn();
    }

    match /settlementRequests/{requestId} {
      allow read, write: if signedIn();
    }

    match /kycRequests/{requestId} {
      allow read, write: if signedIn();
    }

    match /supportTickets/{ticketId} {
      allow read, write: if signedIn();
    }

    // Unified transaction ledger added for admin search/export.
    match /transactions/{transactionId} {
      allow read, write: if signedIn();
    }

    // Marketing content is readable by signed-in users; editable by admins.
    match /marketingItems/{itemId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Audit logs are admin-only.
    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Admin authorization. Owner can bootstrap and manage admins.
    match /adminUsers/{email} {
      allow read: if signedIn();
      allow write: if isOwner();
    }

    // System config and backup metadata.
    match /systemConfig/{configId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Deny anything unknown by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
